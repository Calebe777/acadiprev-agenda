# ============================================================
# .env.production.example — Copie para .env na VPS e preencha
# Gere os segredos com: bash scripts/gen-secrets.sh
# ============================================================

# ---- Porta HTTP no HOST ----
# Default 8090 (escolha qualquer porta livre na VPS, ex.: 8090, 9080, 18080…)
HTTP_PORT=8090

# ---- Django ----
SECRET_KEY=COLE-A-CHAVE-GERADA-AQUI
DEBUG=False
# Coloque o IP público da VPS + qualquer hostname que for usar.
# Pode listar vários separados por vírgula.
ALLOWED_HOSTS=SEU_IP_DA_VPS,localhost,127.0.0.1

# HTTPS desligado (acesso HTTP via IP). Mude para True quando puser TLS.
USE_HTTPS=False

# Origens confiáveis para CSRF (necessário pro /admin funcionar via POST)
# Inclua a porta se não for 80/443.
CSRF_TRUSTED_ORIGINS=http://SEU_IP_DA_VPS:8090

# ---- Banco de dados (Postgres no compose) ----
DB_NAME=agenda_db
DB_USER=agenda
DB_PASSWORD=TROQUE-POR-SENHA-FORTE
DB_HOST=db
DB_PORT=5432

# ---- Redis (cache, channels, celery) ----
REDIS_URL=redis://redis:6379/0

# ---- JWT (RS256) ----
# As chaves são geradas automaticamente no primeiro boot do container api,
# em /app/keys (volume nomeado jwt_keys). Pode deixar como está.
JWT_PRIVATE_KEY_PATH=/app/keys/private.pem
JWT_PUBLIC_KEY_PATH=/app/keys/public.pem
JWT_ACCESS_TOKEN_LIFETIME_MINUTES=60
JWT_REFRESH_TOKEN_LIFETIME_DAYS=7

# ---- S3 / MinIO ----
AWS_ACCESS_KEY_ID=minioadmin
AWS_SECRET_ACCESS_KEY=TROQUE-POR-SENHA-FORTE-MINIO
AWS_STORAGE_BUCKET_NAME=agenda-anexos
AWS_S3_ENDPOINT_URL=http://minio:9000
AWS_S3_REGION_NAME=us-east-1

# ---- Celery ----
CELERY_BROKER_URL=redis://redis:6379/1
CELERY_RESULT_BACKEND=redis://redis:6379/2

# ---- E-mail (opcional, deixe em branco para não enviar) ----
EMAIL_HOST=
EMAIL_PORT=587
EMAIL_HOST_USER=
EMAIL_HOST_PASSWORD=
DEFAULT_FROM_EMAIL=Agenda Hora a Hora <noreply@agenda.app>

# ---- Sentry (opcional) ----
SENTRY_DSN=

# ---- CORS ----
# Coloque a URL pública que o frontend vai usar.
CORS_ALLOWED_ORIGINS=http://SEU_IP_DA_VPS:8090
