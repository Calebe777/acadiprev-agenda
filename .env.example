# ============================================================
# Agenda Hora a Hora — Variáveis de Ambiente
# Copie para .env e preencha os valores
# ============================================================

# Django
SECRET_KEY=sua-chave-secreta-aqui-gere-com-python-secrets
DEBUG=True
ALLOWED_HOSTS=acadiprev.localhost,carvalho.localhost,localhost,127.0.0.1

# Banco de dados
DB_NAME=agenda_db
DB_USER=agenda
DB_PASSWORD=agenda_secret
DB_HOST=db
DB_PORT=5432

# Redis
REDIS_URL=redis://redis:6379/0

# JWT (RS256) — gere com: openssl genrsa -out private.pem 2048
JWT_PRIVATE_KEY_PATH=/app/keys/private.pem
JWT_PUBLIC_KEY_PATH=/app/keys/public.pem
JWT_ACCESS_TOKEN_LIFETIME_MINUTES=60
JWT_REFRESH_TOKEN_LIFETIME_DAYS=7

# S3 / MinIO
AWS_ACCESS_KEY_ID=minioadmin
AWS_SECRET_ACCESS_KEY=minioadmin123
AWS_STORAGE_BUCKET_NAME=agenda-anexos
AWS_S3_ENDPOINT_URL=http://minio:9000
AWS_S3_REGION_NAME=us-east-1

# Celery
CELERY_BROKER_URL=redis://redis:6379/1
CELERY_RESULT_BACKEND=redis://redis:6379/2

# Email (opcional)
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_HOST_USER=seu@email.com
EMAIL_HOST_PASSWORD=senha-app
DEFAULT_FROM_EMAIL=Agenda Hora a Hora <noreply@agenda.app>

# Sentry (opcional)
SENTRY_DSN=

# CORS
CORS_ALLOWED_ORIGINS=http://acadiprev.localhost:3000,http://carvalho.localhost:3000
